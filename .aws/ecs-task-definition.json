{
  "family": "ma2050-ecs-app",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::791209948816:role/service-role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "app",
      "image": "791209948816.dkr.ecr.us-east-1.amazonaws.com/ma2050-ecs-app:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "PORT", "value": "80" },
        { "name": "NODE_ENV", "value": "production" },
        { "name": "DB_HOST", "value": "ma2050-ecs-db.cupm0iesqczk.us-east-1.rds.amazonaws.com" },
        { "name": "DB_PORT", "value": "5432" },
        { "name": "DB_NAME", "value": "sistema_gestao_publica" },
        { "name": "DB_USER", "value": "postgres" },
        { "name": "DB_SSL", "value": "no-verify" }
      ],
      "secrets": [
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:791209948816:secret:ma2050-ecs-db-rds-credentials-In1XUV:password::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-create-group": "true",
          "awslogs-group": "/ecs/ma2050-ecs-app",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
